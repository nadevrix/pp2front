# ─── Supabase ───────────────────────────────────────────────
# Mismas credenciales que pollar-backend (anon key, no service role).
# El login es Google OAuth — configurá el provider en:
# Supabase Dashboard → Authentication → Providers → Google
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiI...

# ─── Backend ────────────────────────────────────────────────
# URL pública del pollar-backend (sin trailing slash)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# ─── Stellar ────────────────────────────────────────────────
# Red Stellar a la que apunta el backend. Si no se setea, los links a
# Stellar Expert y los QR SEP-7 caen a TESTNET por defecto.
# Para mainnet: NEXT_PUBLIC_STELLAR_NETWORK=MAINNET
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
