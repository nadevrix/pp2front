# ─── Supabase ───────────────────────────────────────────────
# Mismas credenciales que pollar-backend (anon key, no service role)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiI...

# Service role key — server-only (sin NEXT_PUBLIC_). La usa /api/auth/signup
# para crear usuarios con admin.createUser({email_confirm:true}) y así
# evitar el rate limit de SMTP gratis de Supabase. Sacala de:
# Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiI...

# ─── Backend ────────────────────────────────────────────────
# URL pública del pollar-backend (sin trailing slash)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
